# NepaliDirectory — environment template (prompt §18)
# Copy to `.env.local` (Next.js) and fill in. NEVER commit real keys — `.gitignore` ignores
# `.env*` except this example. Model IDs/limits are PLACEHOLDERS — verify current free-tier
# names, quotas, feed URLs, and Google Places caching policy at build time (prompt §20.11).

# --- Feature master switches (all AI off until explicitly enabled) ---
AI_ENABLED=false
# Keeps public AI search/chat working with zero provider keys by using local directory data only.
# Set false if you want disabled AI switches to return 503 instead.
PUBLIC_AI_FALLBACK=true
BLOG_ENGINE_ENABLED=false
BLOG_AUTOPUBLISH=false
CONCIERGE_ENABLED=false
CRAWLER_ENABLED=false

# --- Providers (user supplies keys). Verify current free-tier model IDs before use. ---
AI_PRIMARY=gemini
AI_FALLBACKS=groq,openrouter
GEMINI_API_KEY=
GEMINI_MODEL=            # e.g. a current free Gemini flash model — confirm at build
GEMINI_EMBED_MODEL=      # confirm current embedding model + its dimension
GROQ_API_KEY=
GROQ_MODEL=              # e.g. a current free Llama model on Groq
OPENROUTER_API_KEY=
OPENROUTER_MODEL=        # a current ':free' model
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=bge-m3     # local, free, strong on Nepali
EMBEDDING_DIM=768             # MUST match chosen embed model; migrations use this

# --- Budgets / limits (tune per real free-tier quotas; set caps ~80% of real limits) ---
GEMINI_DAILY_TOKEN_CAP=1000000
GROQ_DAILY_TOKEN_CAP=500000
ENRICH_DAILY_CAP=300
AI_CACHE_TTL_DAYS=30

# --- Data acquisition ---
OSM_PBF_URL=https://download.geofabrik.de/asia/nepal-latest.osm.pbf
GOOGLE_PLACES_API_KEY=        # OPTIONAL, on-demand only (claim/admin) — never batch
CRAWLER_USER_AGENT=NepaliDirectoryBot/1.0 (+https://www.nepalidirectory.com/bot)

# --- Trends ---
TREND_SCAN_CRON=0 0 6,16 * * *   # 06:00 & 16:00 NPT (set app TZ Asia/Kathmandu)
BLOG_MAX_PER_DAY=3
BRAND_SAFETY_BLOCKLIST=politics,election,accident,death,disaster,crime,murder,rape,communal,adult
YOUTUBE_API_KEY=             # optional
REDDIT_USER_AGENT=nepalidirectory/1.0 by u/yourname

# --- Auto-blog publisher (posts run automatically; each cycle publishes AT MOST one new,
#     dedup-checked post). The Vercel Cron in vercel.json (GET /api/cron/blog) drives the cadence
#     on serverless; the schedule there is the source of truth, NOT an in-process timer. ---
BLOG_AUTOPUBLISH_MIN_CONFIDENCE=0.6   # 0..1; post must clear this AND fact-check "pass" to publish
BLOG_AUTOPUBLISH_INTERVAL_MS=300000   # only used by the long-running-server timer, not the cron
# Secret the cron route checks. Vercel auto-sends `Authorization: Bearer $CRON_SECRET` on cron hits.
# Set the SAME value in your Vercel project env and here. Generate with e.g. `openssl rand -hex 32`.
CRON_SECRET=
# Optional alt header (x-blog-auto-secret) for an external scheduler (GitHub Actions / cron-job.org).
BLOG_AUTO_SECRET=

# --- Supabase (the database) ---
# Publishable (anon) key is browser-safe; protected by Row Level Security.
NEXT_PUBLIC_SUPABASE_URL=               # https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=   # sb_publishable_... (anon)
SUPABASE_SERVICE_ROLE_KEY=              # server-only; bypasses RLS (background jobs/imports)

# Postgres connection string (Supabase > Settings > Database). Backs blog_posts persistence + the
# SKIP-LOCKED job queue + pgvector. When unset, stores fall back to in-memory (serverless-incompatible).
# For Vercel/serverless use the TRANSACTION POOLER (Supavisor), NOT the direct db.<ref>:5432 host
# (that one is IPv6-only and times out). Copy it from Supabase > Connect > Transaction pooler.
# URL-encode reserved chars in the password (e.g. '#' -> %23).
DATABASE_URL=                # postgresql://postgres.<ref>:<pwd>@aws-1-<region>.pooler.supabase.com:6543/postgres

# --- Site ---
SITE_NAME=NepaliDirectory
SITE_URL=https://www.nepalidirectory.com
APP_TIMEZONE=Asia/Kathmandu
